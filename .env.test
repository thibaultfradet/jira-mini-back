# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# DATABASE_URL is only defined in .env.dev, so it must be redeclared here for the test env.
# The "_test" suffix is added automatically by config/packages/doctrine.yaml (when@test)
# → the database actually used is "app_test". Do NOT write app_test in the URL.
DATABASE_URL="mysql://app:password@database:3306/app?serverVersion=8&charset=utf8mb4"

# null transport: no email is actually sent during tests, but the test env
# message_logger still collects messages, so assertEmailCount() works. Avoids
# depending on the mailpit container to make the suite pass.
MAILER_DSN=null://null
